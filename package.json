{
  "name": "marriott-folio-workflow",
  "version": "0.1.0",
  "private": true,
  "description": "PDF extraction and sanitization workflow for Marriott folio processing.",
  "type": "commonjs",
  "main": "electron/main.js",
  "bin": {
    "marriott-folio": "./apps/cli/index.js"
  },
  "scripts": {
    "cli": "node apps/cli/index.js",
    "desktop": "electron .",
    "build:mac": "electron-builder --mac dir"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "asia.ryy.marriottfolio",
    "productName": "Marriott Folio Workflow",
    "files": [
      "apps/**/*",
      "src/**/*",
      "electron/**/*",
      "package.json",
      "README.md"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "src/pdf/sanitize-visible-text.swift",
        "to": "swift/sanitize-visible-text.swift"
      },
      {
        "from": "src/pdf/extract-visible-text.swift",
        "to": "swift/extract-visible-text.swift"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  }
}
